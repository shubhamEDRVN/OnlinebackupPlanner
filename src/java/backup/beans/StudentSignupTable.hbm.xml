<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="backup.beans">
    <class name="StudentSignupTable" table="studentsignup_hbnet">
        <id name="studentId" column="studentId"></id>
        <property name ="studentPassword" column="studentPassword"></property>
        <property name ="studentName" column="studentName"></property>
        <property name ="collegeName" column="collegeName"></property>
        <property name ="mailId" column="mailId"></property>
        <property name ="contactNo" column="contactNo"></property>

        
    </class>
</hibernate-mapping>
